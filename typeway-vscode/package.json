{
  "name": "typeway-migrate",
  "displayName": "Typeway Migration Tool",
  "description": "Convert between Axum and Typeway code in your editor",
  "version": "0.1.0",
  "publisher": "typeway",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": [
    "onLanguage:rust"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "typeway.convertToTypeway",
        "title": "Typeway: Convert Axum → Typeway"
      },
      {
        "command": "typeway.convertToAxum",
        "title": "Typeway: Convert Typeway → Axum"
      },
      {
        "command": "typeway.checkFile",
        "title": "Typeway: Check Current File"
      },
      {
        "command": "typeway.convertToTypewayDryRun",
        "title": "Typeway: Preview Axum → Typeway Conversion"
      },
      {
        "command": "typeway.convertToAxumDryRun",
        "title": "Typeway: Preview Typeway → Axum Conversion"
      }
    ],
    "configuration": {
      "title": "Typeway",
      "properties": {
        "typeway.migrateBinaryPath": {
          "type": "string",
          "default": "typeway-migrate",
          "description": "Path to the typeway-migrate binary"
        },
        "typeway.createBackups": {
          "type": "boolean",
          "default": true,
          "description": "Create .bak backup files before converting"
        }
      }
    },
    "menus": {
      "editor/context": [
        {
          "command": "typeway.convertToTypeway",
          "when": "editorLangId == rust",
          "group": "typeway"
        },
        {
          "command": "typeway.convertToAxum",
          "when": "editorLangId == rust",
          "group": "typeway"
        },
        {
          "command": "typeway.checkFile",
          "when": "editorLangId == rust",
          "group": "typeway"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  }
}
